{
  "info": {
    "name": "Resume RAG API",
    "_postman_id": "resume-rag-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "supabase_url",
      "value": "https://kodnlecgztfqhkflwcfx.supabase.co",
      "type": "string"
    },
    {
      "key": "supabase_anon_key",
      "value": "YOUR_SUPABASE_ANON_KEY",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Query Resume (Production)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{supabase_anon_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"What programming languages does the candidate know?\",\n  \"n_results\": 5\n}"
        },
        "url": {
          "raw": "{{supabase_url}}/functions/v1/resume-rag",
          "host": ["{{supabase_url}}"],
          "path": ["functions", "v1", "resume-rag"]
        }
      }
    },
    {
      "name": "Query Resume (Local)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"What are the candidate's main skills?\",\n  \"n_results\": 5\n}"
        },
        "url": {
          "raw": "http://localhost:54321/functions/v1/resume-rag",
          "host": ["http://localhost:54321"],
          "path": ["functions", "v1", "resume-rag"]
        }
      }
    }
  ]
}
